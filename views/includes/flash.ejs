<% if (success && success.length > 0) { %>
<div class="container">
    <div class="alert alert-success alert-dismissible fade show col-md-6 mx-auto shadow-sm" role="alert">
        <strong>Success:</strong> <%= success %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
</div>
<% } %>

<% if (error && error.length > 0) { %>
<div class="container">
    <div class="alert alert-danger alert-dismissible fade show col-md-6 mx-auto shadow-sm" role="alert">
        <strong>Error:</strong> <%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
</div>
<% } %>